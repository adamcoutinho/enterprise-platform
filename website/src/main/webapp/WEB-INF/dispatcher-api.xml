<!--            <mvc:mapping path="/**"/>-->
<!--            <bean class="com.main.ep.website.server.interceptor.MyCustomInterceptor"/>-->
<!--        </mvc:interceptor>-->
<!--    </mvc:interceptors>-->




</beans>
